# Database (Neon)
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/interviewprepai?sslmode=require

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Upstash Redis (optional, for price caching)
# Create new database at: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# OpenAI (required for embeddings and chat generation)
OPENAI_API_KEY=...

# Anthropic (required for reconciliation when models disagree)
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith (optional but recommended)
# LangSmith (optional - for tracing)
LANGCHAIN_TRACING_V2=false # true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=interview-prep-ai

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up